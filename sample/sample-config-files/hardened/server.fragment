# Server-side cryptographic floor / peer verification baseline.
# Customize curves (tls-groups), cipher suites, and NCP behaviour per «openvpn --show-*»
# outputs and organisational policy — see contrib/aureon-hardening/GUIDE.rst

tls-version-min 1.2

remote-cert-tls client


data-ciphers AES-256-GCM:CHACHA20-POLY1305:AES-128-GCM
tls-ciphersuites TLS_AES_256_GCM_SHA384:TLS_AES_128_GCM_SHA256:TLS_CHACHA20_POLY1305_SHA256
